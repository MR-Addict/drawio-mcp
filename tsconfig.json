{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "types": ["node"],

    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "verbatimModuleSyntax": true,

    "baseUrl": "./",
    "rootDir": "src",
    "outDir": "./dist"
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
